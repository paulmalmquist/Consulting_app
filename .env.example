# ────────────────────────────────────────────────────────────────────
# Root-level env reference — single runtime configuration.
# Copy to .env.local and fill in real values.
# Sub-projects: backend/.env.example, repo-b/.env.example.
# ────────────────────────────────────────────────────────────────────

# Shared Supabase / Postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# Supabase (for document storage signed URLs)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
STORAGE_BUCKET=documents

# CORS (comma-separated origins allowed for the backend)
ALLOWED_ORIGINS=https://www.paulmalmquist.com,https://paulmalmquist.com

# Frontend ports (used by dev.sh for local development)
FRONTEND_PORT=3001
BACKEND_PORT=8000

# AI Gateway (set on backend — Railway/Render)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_CHAT_MODEL=gpt-5-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PsychRAG clinical module
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# PSYCHRAG_ANTHROPIC_MODEL=claude-sonnet-4-0
# PSYCHRAG_OPENAI_MODEL_FALLBACK=gpt-4o
# PSYCHRAG_EMBEDDING_MODEL=text-embedding-3-large
# PSYCHRAG_EMBEDDING_DIMENSION=3072
