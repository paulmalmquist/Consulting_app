# ────────────────────────────────────────────────────────────────────
# Root-level env reference.
# Copy to .env.local and fill in real values.
# Sub-projects have their own .env files — see backend/, repo-b/, repo-c/.
# ────────────────────────────────────────────────────────────────────

# Shared Supabase / Postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# Supabase (for document storage signed URLs)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
STORAGE_BUCKET=documents

# CORS (comma-separated origins allowed for the backend)
ALLOWED_ORIGINS=http://localhost:3001,https://www.paulmalmquist.com

# Frontend ports (used by dev.sh)
FRONTEND_PORT=3001
BACKEND_PORT=8000

# AI Gateway (set on backend — Railway/Render)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
