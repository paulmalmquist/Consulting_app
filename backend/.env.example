DATABASE_URL=postgresql://postgres:***@db.<project>.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
STORAGE_BUCKET=documents
ALLOWED_ORIGINS=http://localhost:3000

# Local AI sidecar (developer/operator only)
AI_MODE=off
AI_SIDECAR_URL=http://127.0.0.1:7337
AI_TIMEOUT_MS=45000
AI_MAX_PROMPT_BYTES=50000
AI_RETRIEVAL_MAX_FILES=12
AI_RETRIEVAL_MAX_BYTES=200000
AI_ALLOWED_ROOTS=backend,repo-b,repo-c,docs,scripts
