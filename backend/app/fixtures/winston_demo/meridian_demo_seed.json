  "definitions": [
    {
      "definition_id": "9b4d7c63-3f7a-4dc8-8c95-7db5c4e1f401",
      "term": "NOI",
      "structured_metric_key": "noi",
      "owner": "Portfolio Analytics",
      "definition_text": "Net Operating Income represents recurring property-level operating income after vacancy and operating expenses, before debt service, capital expenditures, and fund-level fees.",
      "formula_text": "NOI = Rental Revenue + Other Income - Vacancy Loss - Operating Expenses"
    },
    {
      "definition_id": "9b4d7c63-3f7a-4dc8-8c95-7db5c4e1f402",
      "term": "RevPOR",
      "structured_metric_key": "revpor",
      "owner": "Portfolio Analytics",
      "definition_text": "Revenue Per Occupied Room represents total room revenue divided by occupied room nights.",
      "formula_text": "RevPOR = Room Revenue / Occupied Room Nights"
    },
    {
      "definition_id": "9b4d7c63-3f7a-4dc8-8c95-7db5c4e1f403",
      "term": "DSCR",
      "structured_metric_key": "dscr",
      "owner": "Capital Markets",
      "definition_text": "Debt Service Coverage Ratio measures property NOI relative to required debt service for the same period.",
      "formula_text": "DSCR = NOI / Debt Service"
    },
    {
      "definition_id": "9b4d7c63-3f7a-4dc8-8c95-7db5c4e1f404",
      "term": "WALT",
      "structured_metric_key": "walt",
      "owner": "Asset Management",
      "definition_text": "Weighted Average Lease Term is the rent-weighted average remaining lease term across occupied space.",
      "formula_text": "WALT = Sum(Remaining Lease Term * Rent Weight)"
    },
    {
      "definition_id": "9b4d7c63-3f7a-4dc8-8c95-7db5c4e1f405",
      "term": "TVPI",
      "structured_metric_key": "tvpi",
      "owner": "Investor Relations",
      "definition_text": "Total Value to Paid-In Capital measures realized distributions plus remaining NAV relative to called capital.",
      "formula_text": "TVPI = (Distributed Capital + Residual NAV) / Paid-In Capital"
    },
    {
      "definition_id": "9b4d7c63-3f7a-4dc8-8c95-7db5c4e1f406",
      "term": "IRR",
      "structured_metric_key": "irr",
      "owner": "Investor Relations",
      "definition_text": "Internal Rate of Return is the discount rate that sets net present value of fund cash flows and residual value to zero.",
      "formula_text": "IRR = discount rate where NPV(cash flows) = 0"
    }
  ]
}
