#!/usr/bin/env bash
#
# bmctl — Business Machine Control CLI
#
# A deterministic control plane for the Business Machine app.
# Translates domain-level commands into HTTP calls against local or remote services.
#
# IMPORTANT: "environment" in this tool ALWAYS means a Demo Lab Environment
# exposed by the canonical backend on /v1/environments. It NEVER means a Python venv, conda env, or
# system environment variable. If you need Python tooling, use pip/venv directly.
#
# Usage:
#   bmctl lab env list
#   bmctl lab env create --name "Acme Corp"
#   bmctl lab env create --name "Acme Corp" --industry "Finance"
#   bmctl lab env get    --id <envId>
#   bmctl lab env open   --id <envId>
#   bmctl lab env update --id <envId> --name "New Name"
#   bmctl lab env delete --id <envId>
#   bmctl bos business list
#   bmctl bos business create --name "Acme" --slug "acme"
#   bmctl bos dept list
#   bmctl bos template list
#   bmctl health
#   bmctl help
#
# Environment variables (reads from .env files or shell):
#   LAB_API_BASE_URL      — Demo Lab compatibility surface (default: BOS_API_BASE_URL or http://127.0.0.1:8000)
#   BOS_API_BASE_URL      — Canonical backend (default: http://127.0.0.1:8000)
#   FRONTEND_BASE_URL     — Next.js frontend    (default: http://127.0.0.1:3001)

set -euo pipefail

# ── Defaults ──────────────────────────────────────────────────────
BOS_API_BASE_URL="${BOS_API_BASE_URL:-http://127.0.0.1:8000}"
LAB_API_BASE_URL="${LAB_API_BASE_URL:-${BOS_API_BASE_URL}}"
FRONTEND_BASE_URL="${FRONTEND_BASE_URL:-http://127.0.0.1:3001}"

# ── Helpers ───────────────────────────────────────────────────────
_jq_or_raw() {
  if command -v jq >/dev/null 2>&1; then
    jq "$@"
  else
    cat
  fi
}

_curl() {
  local url="$1"; shift
  local response status_code body
  response=$(curl -s -w "\n%{http_code}" "$@" "$url" 2>&1 || echo -e "\n000")
  status_code=$(echo "$response" | tail -n 1)
  body=$(echo "$response" | sed '$d')

  if [[ "$status_code" -lt 200 || "$status_code" -ge 300 ]]; then
    echo "ERROR: HTTP $status_code from $url" >&2
    echo "$body" | _jq_or_raw '.' 2>/dev/null >&2 || echo "$body" >&2
    return 1
  fi
  echo "$body"
}

_require_arg() {
  local name="$1" value="$2"
  if [[ -z "$value" ]]; then
    echo "ERROR: --${name} is required." >&2
    exit 1
  fi
}

# ── Lab Environment Commands ──────────────────────────────────────
lab_env_list() {
  echo "# Demo Lab Environments"
  echo "# GET ${LAB_API_BASE_URL}/v1/environments"
  echo ""
  local body
  body=$(_curl "${LAB_API_BASE_URL}/v1/environments")
  if command -v jq >/dev/null 2>&1; then
    local count
    count=$(echo "$body" | jq -r '.environments | length')
    echo "$body" | jq -r '.environments[] | "  \(.env_id)  \(.client_name // "(unnamed)")  [\(.industry // "-")]  active=\(.is_active // true)"'
    echo ""
    echo "Total: ${count} environment(s)"
  else
    echo "$body"
  fi
}

lab_env_create() {
  local name="" industry="" industry_type="" notes=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)       name="$2"; shift 2;;
      --industry)   industry="$2"; shift 2;;
      --industry-type) industry_type="$2"; shift 2;;
      --notes)      notes="$2"; shift 2;;
      *) echo "Unknown arg: $1" >&2; exit 1;;
    esac
  done
  _require_arg "name" "$name"

  local payload
  payload=$(jq -n --arg n "$name" --arg i "$industry" --arg it "$industry_type" --arg no "$notes" \
    '{client_name: $n} + (if $i != "" then {industry: $i} else {} end) + (if $it != "" then {industry_type: $it} else {} end) + (if $no != "" then {notes: $no} else {} end)')

  echo "# Creating Demo Lab Environment"
  echo "# POST ${LAB_API_BASE_URL}/v1/environments"
  echo ""
  local body
  body=$(_curl "${LAB_API_BASE_URL}/v1/environments" -X POST -H "Content-Type: application/json" -d "$payload")
  echo "$body" | _jq_or_raw '.'

  if command -v jq >/dev/null 2>&1; then
    local env_id
    env_id=$(echo "$body" | jq -r '.env_id // empty')
    if [[ -n "$env_id" ]]; then
      echo ""
      echo "Created: ${env_id}"
      echo "UI: ${FRONTEND_BASE_URL}/lab/env/${env_id}"
    fi
  fi
}

lab_env_get() {
  local id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2;;
      *) echo "Unknown arg: $1" >&2; exit 1;;
    esac
  done
  _require_arg "id" "$id"

  echo "# Demo Lab Environment: ${id}"
  echo "# GET ${LAB_API_BASE_URL}/v1/environments (filtered)"
  echo ""
  local body
  body=$(_curl "${LAB_API_BASE_URL}/v1/environments")
  if command -v jq >/dev/null 2>&1; then
    echo "$body" | jq --arg id "$id" '.environments[] | select(.env_id == $id)'
  else
    echo "$body"
  fi
}

lab_env_open() {
  local id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2;;
      *) echo "Unknown arg: $1" >&2; exit 1;;
    esac
  done
  _require_arg "id" "$id"

  local url="${FRONTEND_BASE_URL}/lab/env/${id}"
  echo "# Open in browser: ${url}"
  if command -v open >/dev/null 2>&1; then
    open "$url"
  elif command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url"
  else
    echo "(no browser launcher found — copy the URL above)"
  fi
}

lab_env_update() {
  local id="" name="" industry="" industry_type="" is_active="" notes=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id)            id="$2"; shift 2;;
      --name)          name="$2"; shift 2;;
      --industry)      industry="$2"; shift 2;;
      --industry-type) industry_type="$2"; shift 2;;
      --active)        is_active="$2"; shift 2;;
      --notes)         notes="$2"; shift 2;;
      *) echo "Unknown arg: $1" >&2; exit 1;;
    esac
  done
  _require_arg "id" "$id"

  local payload
  payload=$(jq -n \
    --arg n "$name" --arg i "$industry" --arg it "$industry_type" --arg a "$is_active" --arg no "$notes" \
    '(if $n  != "" then {client_name: $n} else {} end) +
     (if $i  != "" then {industry: $i} else {} end) +
     (if $it != "" then {industry_type: $it} else {} end) +
     (if $a  != "" then {is_active: ($a == "true")} else {} end) +
     (if $no != "" then {notes: $no} else {} end)')

  echo "# Updating Demo Lab Environment: ${id}"
  echo "# PATCH ${LAB_API_BASE_URL}/v1/environments/${id}"
  echo ""
  local body
  body=$(_curl "${LAB_API_BASE_URL}/v1/environments/${id}" -X PATCH -H "Content-Type: application/json" -d "$payload")
  echo "$body" | _jq_or_raw '.'
}

lab_env_delete() {
  local id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) id="$2"; shift 2;;
      *) echo "Unknown arg: $1" >&2; exit 1;;
    esac
  done
  _require_arg "id" "$id"

  echo "# Deleting Demo Lab Environment: ${id}"
  echo "# DELETE ${LAB_API_BASE_URL}/v1/environments/${id}"
  echo ""
  local body
  body=$(_curl "${LAB_API_BASE_URL}/v1/environments/${id}" -X DELETE)
  echo "$body" | _jq_or_raw '.'
}

# ── Business OS Commands ──────────────────────────────────────────
bos_business_list() {
  echo "# Business OS Businesses"
  echo "# GET ${BOS_API_BASE_URL}/api/businesses"
  echo ""
  echo "(Note: BOS does not have a list-all-businesses endpoint.)"
  echo "Use the frontend onboarding flow or query the database directly."
  echo "Available catalog endpoints:"
  echo "  GET /api/templates    — provisioning templates"
  echo "  GET /api/departments  — department catalog"
}

bos_business_create() {
  local name="" slug="" region="us"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)   name="$2"; shift 2;;
      --slug)   slug="$2"; shift 2;;
      --region) region="$2"; shift 2;;
      *) echo "Unknown arg: $1" >&2; exit 1;;
    esac
  done
  _require_arg "name" "$name"
  if [[ -z "$slug" ]]; then
    slug=$(echo "$name" | tr '[:upper:]' '[:lower:]' | tr ' ' '-' | tr -cd 'a-z0-9-')
  fi

  local payload
  payload=$(jq -n --arg n "$name" --arg s "$slug" --arg r "$region" \
    '{name: $n, slug: $s, region: $r}')

  echo "# Creating Business OS Business"
  echo "# POST ${BOS_API_BASE_URL}/api/businesses"
  echo ""
  local body
  body=$(_curl "${BOS_API_BASE_URL}/api/businesses" -X POST -H "Content-Type: application/json" -d "$payload")
  echo "$body" | _jq_or_raw '.'

  if command -v jq >/dev/null 2>&1; then
    local biz_id
    biz_id=$(echo "$body" | jq -r '.business_id // empty')
    if [[ -n "$biz_id" ]]; then
      echo ""
      echo "Created business: ${biz_id} (slug: ${slug})"
    fi
  fi
}

bos_dept_list() {
  echo "# Business OS Department Catalog"
  echo "# GET ${BOS_API_BASE_URL}/api/departments"
  echo ""
  local body
  body=$(_curl "${BOS_API_BASE_URL}/api/departments")
  if command -v jq >/dev/null 2>&1; then
    echo "$body" | jq -r '.[] | "  \(.key)  \(.label)  \(.icon)"' 2>/dev/null || echo "$body" | jq '.'
  else
    echo "$body"
  fi
}

bos_template_list() {
  echo "# Business OS Templates"
  echo "# GET ${BOS_API_BASE_URL}/api/templates"
  echo ""
  local body
  body=$(_curl "${BOS_API_BASE_URL}/api/templates")
  echo "$body" | _jq_or_raw '.'
}

# ── Health ────────────────────────────────────────────────────────
health_check() {
  echo "# Health Check"
  echo ""
  local ok=true

  echo -n "  Business OS (${BOS_API_BASE_URL}): "
  if _curl "${BOS_API_BASE_URL}/health" >/dev/null 2>&1; then
    echo "OK"
  else
    echo "DOWN"
    ok=false
  fi

  echo -n "  Demo Lab (/v1 via backend) (${LAB_API_BASE_URL}): "
  if _curl "${LAB_API_BASE_URL}/health" >/dev/null 2>&1; then
    echo "OK"
  else
    echo "DOWN"
    ok=false
  fi

  echo -n "  Frontend   (${FRONTEND_BASE_URL}): "
  if curl -s -o /dev/null -w "%{http_code}" "${FRONTEND_BASE_URL}/" 2>/dev/null | grep -q "200\|304"; then
    echo "OK"
  else
    echo "DOWN"
    ok=false
  fi

  echo ""
  if $ok; then
    echo "All services healthy."
  else
    echo "Some services are down. Run: ./dev.sh"
  fi
}

# ── Help ──────────────────────────────────────────────────────────
show_help() {
  cat <<'HELP'
bmctl — Business Machine Control CLI

TERMINOLOGY
  "environment" = Demo Lab Environment (a client workspace in the lab system).
  "business"    = Business OS business/workspace record.
  These are PRODUCT DOMAIN objects, NOT Python/conda/system environments.

COMMANDS
  Lab (Demo Lab compatibility routes on backend, default port 8000):
    bmctl lab env list                          List all Demo Lab environments
    bmctl lab env create --name "..." [opts]    Create a new environment
    bmctl lab env get    --id <envId>           Get environment details
    bmctl lab env open   --id <envId>           Open environment in browser
    bmctl lab env update --id <envId> [opts]    Update environment fields
    bmctl lab env delete --id <envId>           Delete an environment

  Business OS (backend, port 8000):
    bmctl bos business list                     List businesses (info)
    bmctl bos business create --name "..." --slug "..."  Create a business
    bmctl bos dept list                         List department catalog
    bmctl bos template list                     List provisioning templates

  System:
    bmctl health                                Check all service health
    bmctl help                                  Show this help

CREATE OPTIONS
  --name "..."          Client/business name (required)
  --industry "..."      Industry classification
  --industry-type "..." Industry sub-type
  --notes "..."         Free-text notes
  --slug "..."          URL-safe identifier (auto-generated if omitted)
  --region "..."        Region code (default: us)

UPDATE OPTIONS
  --name "..."          New client name
  --industry "..."      New industry
  --active true|false   Enable/disable environment

ENVIRONMENT VARIABLES
  LAB_API_BASE_URL      Demo Lab compatibility base (default: BOS_API_BASE_URL or http://127.0.0.1:8000)
  BOS_API_BASE_URL      Canonical backend       (default: http://127.0.0.1:8000)
  FRONTEND_BASE_URL     Next.js frontend    (default: http://127.0.0.1:3001)

EXAMPLES
  bmctl lab env list
  bmctl lab env create --name "Acme Corp" --industry "Finance"
  bmctl bos template list
  bmctl health
HELP
}

# ── Router ────────────────────────────────────────────────────────
main() {
  if [[ $# -eq 0 ]]; then
    show_help
    exit 0
  fi

  case "$1" in
    lab)
      shift
      case "${1:-}" in
        env|environment|environments)
          shift
          case "${1:-}" in
            list|ls)    shift; lab_env_list "$@";;
            create|new) shift; lab_env_create "$@";;
            get|show)   shift; lab_env_get "$@";;
            open)       shift; lab_env_open "$@";;
            update)     shift; lab_env_update "$@";;
            delete|rm)  shift; lab_env_delete "$@";;
            *)
              echo "Unknown lab env command: ${1:-}" >&2
              echo "Run: bmctl help" >&2
              exit 1
              ;;
          esac
          ;;
        *)
          echo "Unknown lab resource: ${1:-}" >&2
          echo "Run: bmctl help" >&2
          exit 1
          ;;
      esac
      ;;
    bos)
      shift
      case "${1:-}" in
        business|businesses)
          shift
          case "${1:-}" in
            list|ls)    shift; bos_business_list "$@";;
            create|new) shift; bos_business_create "$@";;
            *)
              echo "Unknown bos business command: ${1:-}" >&2
              echo "Run: bmctl help" >&2
              exit 1
              ;;
          esac
          ;;
        dept|department|departments)
          shift
          case "${1:-}" in
            list|ls) shift; bos_dept_list "$@";;
            *)
              echo "Unknown bos dept command: ${1:-}" >&2
              exit 1
              ;;
          esac
          ;;
        template|templates)
          shift
          case "${1:-}" in
            list|ls) shift; bos_template_list "$@";;
            *)
              echo "Unknown bos template command: ${1:-}" >&2
              exit 1
              ;;
          esac
          ;;
        *)
          echo "Unknown bos resource: ${1:-}" >&2
          echo "Run: bmctl help" >&2
          exit 1
          ;;
      esac
      ;;
    health)  health_check;;
    help|-h|--help) show_help;;
    *)
      echo "Unknown command: $1" >&2
      echo "Run: bmctl help" >&2
      exit 1
      ;;
  esac
}

main "$@"
