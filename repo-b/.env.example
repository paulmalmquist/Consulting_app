# ── Frontend (repo-b) ──────────────────────────────────────────────
# Business OS backend (FastAPI at backend/)
NEXT_PUBLIC_BOS_API_BASE_URL=http://localhost:8000

# Demo Lab backend (FastAPI at repo-c/)
NEXT_PUBLIC_DEMO_API_BASE_URL=http://localhost:8001

# Legacy single URL (deprecated — use the two above)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase public (anon) — used by frontend for storage only
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Auth
# Admin code — grants access to /admin (environment management)
ADMIN_INVITE_CODE=admin-change-me
# Environment code — grants access to environments as env_user
ENV_INVITE_CODE=env-change-me
# Legacy: kept for backward compatibility during transition
DEMO_INVITE_CODE=change-me

# Local AI sidecar (developer/operator only)
NEXT_PUBLIC_AI_MODE=off
AI_MODE=off
AI_SIDECAR_URL=http://127.0.0.1:7337
AI_SIDECAR_PORT=7337
AI_SIDECAR_TOKEN=
# Winston assistant adapter flags
# Use existing API contracts and codex bridge diagnostics
USE_CODEX_SERVER=true
USE_MOCKS=false
# Browser-safe variants
NEXT_PUBLIC_USE_CODEX_SERVER=true
NEXT_PUBLIC_USE_MOCKS=false
# Optional: working directory for Codex runs (defaults to repo-b cwd)
# AI_WORKDIR=/absolute/path/to/Consulting_app
