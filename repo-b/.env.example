# ── Frontend (repo-b) ──────────────────────────────────────────────
# Single canonical backend origin (server-side only, NOT NEXT_PUBLIC_).
# The /bos/* proxy forwards all browser API calls to this URL.
# In production, set to your Railway/Render/Fly backend URL.
BOS_API_ORIGIN=http://localhost:8000

# Supabase public (anon) — used by frontend for storage only
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Auth
# Admin code — grants access to /admin (environment management)
ADMIN_INVITE_CODE=admin-change-me
# Environment code — grants access to environments as env_user
ENV_INVITE_CODE=env-change-me

# AI Gateway (OpenAI Chat Completions + RAG)
# Set OPENAI_API_KEY on the backend (Railway/Render) — NOT in frontend env.
# The frontend proxies /api/ai/gateway/* to the backend.
