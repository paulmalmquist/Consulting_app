# ── Frontend (repo-b) ──────────────────────────────────────────────
# Business OS backend (FastAPI at backend/)
NEXT_PUBLIC_BOS_API_BASE_URL=http://localhost:8000

# Demo Lab backend (FastAPI at repo-c/)
NEXT_PUBLIC_DEMO_API_BASE_URL=http://localhost:8001

# Legacy single URL (deprecated — use the two above)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase public (anon) — used by frontend for storage only
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Auth
DEMO_INVITE_CODE=change-me

# Optional upstream proxy for /api/v1/*.
# If unset or upstream returns 404/501, repo-b serves local fallback handlers.
DEMO_API_ORIGIN=

# DB for real /api/v1/environments reads/writes.
# Lab fallback endpoints still work without this for non-DB-backed flows.
DATABASE_URL=

# Local AI sidecar (developer/operator only)
NEXT_PUBLIC_AI_MODE=off
