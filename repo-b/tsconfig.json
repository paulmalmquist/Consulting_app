{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    ".next"
  ],
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "src/app/layout.tsx",
    "src/app/api/market-intelligence/landing/route.ts",
    "src/app/lab/env/[envId]/page.tsx",
    "src/app/lab/env/[envId]/markets/page.tsx",
    "src/components/EnvProvider.tsx",
    "src/components/lab/environments/constants.ts",
    "src/components/market/RegimeClassifierWidget.tsx",
    "src/components/ui/Button.tsx",
    "src/components/ui/Card.tsx",
    "src/components/ui/buttonVariants.ts",
    "src/lib/api.ts",
    "src/lib/bos-api.ts",
    "src/lib/lab/DepartmentRegistry.ts",
    "src/lib/market-intelligence/**/*.ts",
    "src/lib/supabase-client.ts"
  ]
}
