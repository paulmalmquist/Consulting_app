{
  "name": "demo-lab-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:repe:e2e": "playwright test tests/repe/repe-workspace.spec.ts --config=playwright.config.ts --project=chromium",
    "test:repe:full": "npm run test:unit && npm run test:repe:e2e",
    "test:qa-reports": "playwright test tests/reports-qa.spec.ts --config=playwright.local.config.ts",
    "qa:loop": "node scripts/qa_loop.mjs",
    "test:prod": "playwright test tests/production/re-production.spec.ts --config=playwright.production.config.ts --project=chromium",
    "prod:loop": "node scripts/production-loop.mjs",
    "db:dry": "node db/schema/apply.js --dry-run",
    "db:apply": "NODE_TLS_REJECT_UNAUTHORIZED=0 node db/schema/apply.js",
    "db:verify": "NODE_TLS_REJECT_UNAUTHORIZED=0 node db/schema/verify.js",
    "db:test": "NODE_TLS_REJECT_UNAUTHORIZED=0 node db/tests/schema.test.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.98.0",
    "@types/leaflet": "^1.9.21",
    "@xyflow/react": "^12.10.2",
    "docx": "^9.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.539.0",
    "next": "14.2.4",
    "pg": "^8.13.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-leaflet": "4.2.1",
    "recharts": "^2.15.4",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@playwright/test": "^1.41.2",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.9",
    "autoprefixer": "10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.4",
    "jsdom": "^24.1.1",
    "playwright": "^1.41.2",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.4",
    "typescript": "5.4.5",
    "vitest": "^2.1.5"
  }
}
