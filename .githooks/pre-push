#!/usr/bin/env bash
set -euo pipefail
branch="$(git branch --show-current)"
if [[ -z "${ORCH_ALLOW_PROTECTED_PUSH:-}" ]]; then
  if [[ "$branch" == "main" || "$branch" == "master" || "$branch" == "production" ]]; then
    echo "Blocked: pushes from protected branch '$branch' are not allowed by orchestration policy." >&2
    echo "Set ORCH_ALLOW_PROTECTED_PUSH=1 for explicit emergency override." >&2
    exit 1
  fi
fi
