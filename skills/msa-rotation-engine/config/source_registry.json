{
  "research_categories": {
    "transaction_activity": {
      "description": "Recent sales comps, deed transfers, distress signals, buyer mix",
      "sources": [
        {"name": "County Assessor/Recorder", "type": "web_search", "query_template": "{zone_name} real estate sales {asset_class} {year}"},
        {"name": "Public Records - Lis Pendens", "type": "web_search", "query_template": "{zone_name} lis pendens notices {year}"},
        {"name": "CoStar / LoopNet", "type": "web_search", "query_template": "site:loopnet.com {zone_name} {asset_class} sold"},
        {"name": "Local Business Journal", "type": "web_search", "query_template": "{zone_name} commercial real estate transactions {quarter} {year}"}
      ]
    },
    "supply_pipeline": {
      "description": "Building permits, entitled projects, demolitions, zoning changes",
      "sources": [
        {"name": "City/County Permit Portal", "type": "web_search", "query_template": "{zone_name} building permits {asset_class} {year}"},
        {"name": "Planning Commission", "type": "web_search", "query_template": "{zone_name} planning commission agenda zoning {year}"},
        {"name": "Construction Pipeline", "type": "web_search", "query_template": "{zone_name} new construction {asset_class} pipeline units"},
        {"name": "Demolition Activity", "type": "web_search", "query_template": "{zone_name} demolition permits land development"}
      ]
    },
    "demand_drivers": {
      "description": "Employment, employer moves, migration, transit, education",
      "sources": [
        {"name": "BLS QCEW", "type": "web_fetch", "url_template": "https://data.bls.gov/timeseries/ENU{fips_code}5{industry_code}"},
        {"name": "FRED Employment", "type": "web_fetch", "url_template": "https://fred.stlouisfed.org/series/{msa_employment_series}"},
        {"name": "Census ACS", "type": "web_search", "query_template": "Census ACS {msa_code} population migration income {year}"},
        {"name": "Major Employers", "type": "web_search", "query_template": "{zone_name} major employer expansion relocation {year}"},
        {"name": "Transit Projects", "type": "web_search", "query_template": "{zone_name} transit infrastructure project construction"}
      ]
    },
    "rent_and_occupancy": {
      "description": "Asking rents, concessions, occupancy by vintage, STR penetration",
      "sources": [
        {"name": "Zillow Rental Index", "type": "web_search", "query_template": "Zillow {zone_name} rent index {asset_class} trend"},
        {"name": "Apartments.com", "type": "web_search", "query_template": "site:apartments.com {zone_name} average rent studio 1br 2br"},
        {"name": "Occupancy Data", "type": "web_search", "query_template": "{zone_name} {asset_class} occupancy rate vacancy {year}"},
        {"name": "STR Penetration", "type": "web_search", "query_template": "{zone_name} Airbnb short term rental market share impact"}
      ]
    },
    "capital_markets": {
      "description": "Bank CRE lending, agency volume, CMBS, REIT activity",
      "sources": [
        {"name": "FFIEC Call Reports", "type": "web_search", "query_template": "FFIEC CRE lending {msa_code} bank commercial real estate loan volume"},
        {"name": "Agency Lending", "type": "web_search", "query_template": "Fannie Freddie {zone_name} multifamily lending volume {year}"},
        {"name": "CMBS Delinquency", "type": "web_search", "query_template": "CMBS delinquency special servicing {zone_name} {asset_class}"},
        {"name": "SEC EDGAR", "type": "web_search", "query_template": "site:sec.gov 13F {zone_name} real estate investment {year}"}
      ]
    },
    "regulatory_political": {
      "description": "Rent control, impact fees, OZ status, tax reassessment",
      "sources": [
        {"name": "Rent Control/Stabilization", "type": "web_search", "query_template": "{zone_name} rent control stabilization proposal ordinance"},
        {"name": "Impact Fees", "type": "web_search", "query_template": "{zone_name} development impact fee change {year}"},
        {"name": "Opportunity Zones", "type": "web_search", "query_template": "{zone_name} opportunity zone investment activity qualified"},
        {"name": "Property Tax", "type": "web_search", "query_template": "{zone_name} property tax reassessment millage rate change {year}"}
      ]
    }
  }
}
