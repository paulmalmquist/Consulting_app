{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orchestration Execution Log",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "execution_id", "session_id", "timestamp_utc", "intent", "model_used", "branch", "worktree_path",
    "approval_required", "approval_value_used", "plan_hash", "pre_state_hash", "post_state_hash",
    "files_modified", "lines_added", "lines_removed", "duration_ms", "status", "errors", "rollback_required",
    "hash_prev", "hash_self"
  ],
  "properties": {
    "execution_id": {"type": "string"},
    "session_id": {"type": "string", "format": "uuid"},
    "timestamp_utc": {"type": "string", "format": "date-time"},
    "intent": {"type": "string"},
    "model_used": {"type": "string"},
    "branch": {"type": "string"},
    "worktree_path": {"type": "string"},
    "approval_required": {"type": "boolean"},
    "approval_value_used": {"type": ["string", "null"]},
    "plan_hash": {"type": "string"},
    "pre_state_hash": {"type": "string"},
    "post_state_hash": {"type": "string"},
    "files_modified": {"type": "array", "items": {"type": "string"}},
    "lines_added": {"type": "integer", "minimum": 0},
    "lines_removed": {"type": "integer", "minimum": 0},
    "duration_ms": {"type": "integer", "minimum": 0},
    "status": {"type": "string"},
    "errors": {"type": "array", "items": {"type": "string"}},
    "rollback_required": {"type": "boolean"},
    "hash_prev": {"type": "string"},
    "hash_self": {"type": "string"}
  }
}
