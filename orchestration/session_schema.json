{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Orchestration Session",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id", "model", "reasoning_effort", "branch", "allowed_directories", "allowed_tools",
    "max_files_per_execution", "auto_approval", "created_at", "intent", "risk_level", "status"
  ],
  "properties": {
    "session_id": {"type": "string", "format": "uuid"},
    "model": {"type": "string", "minLength": 1},
    "reasoning_effort": {"type": "string", "enum": ["low", "medium", "high"]},
    "branch": {"type": "string", "pattern": "^feature/[a-f0-9-]+/[a-z_]+$"},
    "allowed_directories": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "allowed_tools": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "max_files_per_execution": {"type": "integer", "minimum": 1},
    "auto_approval": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "intent": {"type": "string"},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
    "status": {"type": "string", "enum": ["active", "paused", "closed"]}
  }
}
